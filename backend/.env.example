APP_ENV=development
APP_NAME=Skeptik Newsroom API
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=sqlite:///./skeptik.db

FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=moonshotai/Kimi-K2.5

TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com

BRIGHTDATA_API_KEY=
BRIGHTDATA_API_URL=https://api.brightdata.com/request
BRIGHTDATA_ZONE=

VIRLO_API_KEY=
VIRLO_API_URL=https://api.virlo.ai/v1/trends/digest

NEWSROOM_AUTOPILOT_ENABLED=true
NEWSROOM_AUTOPILOT_SECONDS=900
NEWSROOM_DEFAULT_REGION=global
NEWSROOM_MIN_SOURCES=3
NEWSROOM_MAX_FALSE_CLAIMS=0
NEWSROOM_MAX_UNCERTAIN_RATIO=0.34
NEWSROOM_MAX_SKEPTIC_SCORE=0.62
NEWSROOM_TARGET_ARTICLE_COUNT=8
